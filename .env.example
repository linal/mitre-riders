# Copy this file to `.env` and fill in real values.
# `.env` is gitignored - never commit real credentials.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# Backend port (default 3001 if unset)
PORT=3001
# 'development' or 'production'
NODE_ENV=development

# Comma-separated list of allowed CORS origins. Use the dev URL locally and
# the production frontend URL in prod. Wildcards are not supported.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4173

# Optional explicit override for the cache directory. Defaults to ./cache in
# development and /data in production (Fly volume mount).
# CACHE_DIR=./cache

# Logging
LOG_LEVEL=info
# Set to 1 for human-readable output during local development.
# LOG_PRETTY=1

# Shared secret for the cache-build cron job (used by Dockerfile.job).
# Anything that knows this header value can call POST /api/build-cache.
CACHE_BUILD_TOKEN=change-me-to-a-long-random-string

# ---------------------------------------------------------------------------
# Frontend - Firebase Web SDK (read by Vite, not by the server)
# Find these in the Firebase console - Project settings - Your apps - Web app.
# ---------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Optional: explicit API base URL the frontend should hit. Leave empty in
# production (the SPA is served by the same Express app) and in dev the Vite
# proxy on /api takes care of routing to localhost:3001.
# VITE_API_BASE_URL=http://localhost:3001

# ---------------------------------------------------------------------------
# Backend - Firebase Admin SDK credentials
# From a service account JSON file: Firebase console - Project settings -
# Service accounts - Generate new private key.
#
# IMPORTANT: keep newlines in FIREBASE_PRIVATE_KEY escaped as \n. Wrap the
# whole value in double quotes if your shell/loader requires it.
# ---------------------------------------------------------------------------
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----\n"

# Alternatively, instead of FIREBASE_CLIENT_EMAIL/FIREBASE_PRIVATE_KEY you can
# point Firebase Admin at a service account file on disk:
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
