# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real credentials.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# Backend port (default 3001 if unset)
PORT=3001
# 'development' or 'production'
NODE_ENV=development

# ---------------------------------------------------------------------------
# Firebase Web SDK (frontend) configuration
# Find these in the Firebase console → Project settings → Your apps → Web app.
# ---------------------------------------------------------------------------
REACT_APP_FIREBASE_API_KEY=your_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id

# ---------------------------------------------------------------------------
# Firebase Admin SDK (backend) credentials
# From a service account JSON file: Firebase console → Project settings →
# Service accounts → Generate new private key.
#
# IMPORTANT: keep newlines in FIREBASE_PRIVATE_KEY escaped as \n. Wrap the
# whole value in double quotes if your shell/loader requires it.
# ---------------------------------------------------------------------------
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----\n"

# Alternatively, instead of FIREBASE_CLIENT_EMAIL/FIREBASE_PRIVATE_KEY you
# can point Firebase Admin at a service account file on disk:
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
