{
  "name": "pelopoints",
  "private": true,
  "version": "1.1.0",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite --force",
    "build": "vite build",
    "preview": "vite preview",
    "build:server": "tsc -p tsconfig.server.json",
    "start-server": "tsx watch src-server/index.ts",
    "start": "concurrently \"serve -s client -l 4173\" \"node dist-server/index.js\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck:client && npm run typecheck:server && npm run typecheck:tests",
    "typecheck:client": "tsc -p tsconfig.client.json --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.tests.json --noEmit",
    "test": "vitest",
    "test:watch": "vitest watch",
    "test:e2e": "playwright test",
    "set-admin": "tsx scripts/set-admin.ts",
    "generate:icons": "tsx scripts/generate-favicons.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.1",
    "firebase": "^11.8.1",
    "firebase-admin": "^13.4.0",
    "helmet": "^8.0.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "puppeteer": "^24.11.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-loading-overlay-ts": "^2.0.2",
    "react-router-dom": "^6.30.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.5",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^4.0.3",
    "@vitest/ui": "^2.1.3",
    "autoprefixer": "^10.4.14",
    "concurrently": "^8.2.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.11.0",
    "jsdom": "^25.0.1",
    "nodemon": "^3.0.1",
    "pino-pretty": "^11.3.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.27",
    "prettier": "^3.3.3",
    "sharp": "^0.34.5",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "vite": "^4.4.5",
    "vitest": "^2.1.3"
  }
}
