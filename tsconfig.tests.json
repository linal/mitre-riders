{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": ["node", "vitest/globals", "@testing-library/jest-dom", "vite/client"]
  },
  "include": ["tests/server/**/*", "tests/client/**/*", "tests/setup.ts"],
  "exclude": ["tests/e2e/**", "node_modules"]
}
